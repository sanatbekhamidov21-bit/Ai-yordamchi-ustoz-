// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String       @id @default(uuid())
  telegramId      BigInt       @unique
  username        String?
  fullName        String
  role            String       @default("STUDENT")
  joinDate        DateTime     @default(now())
  lastActivity    DateTime     @default(now())
  totalHomeworks  Int          @default(0)
  totalCoins      Int          @default(0)
  missedHomeworks Int          @default(0)
  accuracy        Float        @default(0.0)
  groupId         String?
  group           Group?       @relation(fields: [groupId], references: [id])
  submissions     Submission[]
  messages        MessageLog[]
}

model Group {
  id             String     @id @default(uuid())
  telegramId     String?    @unique
  name           String     @unique
  description    String
  googleSheetId  String?    // Individual Google Sheet ID for this group
  createdAt      DateTime   @default(now())
  users          User[]
  homeworks      Homework[]
}

model Homework {
  id          String       @id @default(uuid())
  hwNumber    Int          @unique
  description String
  deadline    DateTime
  createdAt   DateTime     @default(now())
  isActive    Boolean      @default(true)
  groupId     String?
  group       Group?       @relation(fields: [groupId], references: [id])
  submissions Submission[]
}

model Submission {
  id          String   @id @default(uuid())
  userId      String
  hwId        String
  text        String
  score       Int?
  feedback    String?
  submittedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  homework Homework @relation(fields: [hwId], references: [id])
}

model ChannelPost {
  id             String   @id @default(uuid())
  telegramMsgId  Int      @unique
  content        String
  type           String
  viewsCount     Int      @default(0)
  postedAt       DateTime @default(now())
}

model MessageLog {
  id         String   @id @default(uuid())
  userId     String
  chatId     String
  text       String?
  mediaType  String?  // photo, voice, document, none
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ScheduledTask {
  id          String   @id @default(uuid())
  type        String   // POST_MESSAGE, DAILY_STATS, etc.
  payload     String   // JSON string with task data (chatId, text, etc.)
  executeAt   DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}
